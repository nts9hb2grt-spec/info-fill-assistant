{
  "name": "info-fill-assistant",
  "version": "1.0.0",
  "description": "关键词匹配 + 文档抽取 + Excel回填工具",
  "author": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "forceCodeSigning": false
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "mammoth": "^1.12.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1"
  }
}
